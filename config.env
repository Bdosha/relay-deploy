# config.env — VPN deployment settings
# No secrets here. Safe to commit.

# Number of VPN users to generate
NUM_USERS=11

# Xray listen port on exit (Latvia) server
XRAY_PORT=8443

# Reality SNI — must support TLS 1.3
SNI="www.github.com"

# TLS fingerprint
FINGERPRINT="chrome"

# Service UUID for Russia→Latvia Xray link (no vision flow, mux enabled)
SERVICE_UUID="1039e8f1-7dcc-4da6-b2e6-b14f0f0add12"

# ByeDPI settings (DPI bypass SOCKS5 proxy on Russia)
BYEDPI_PORT=1080
BYEDPI_ARGS="--split 1+s --disorder 1 --oob 1 --tlsrec 1+s"

# Domains routed through ByeDPI on Russia (exit with Russian IP, DPI bypass)
BYPASS_DOMAINS=(
    "domain:youtube.com"
    "domain:googlevideo.com"
    "domain:ytimg.com"
    "domain:ggpht.com"
    "domain:youtu.be"
    "domain:youtube-nocookie.com"
    "domain:youtubei.googleapis.com"
    "domain:youtube.googleapis.com"
)

# Cloudflare WARP — route AI/blocked services through Cloudflare instead of direct exit
WARP_ENABLED=true
WARP_PORT=40000

# Domains routed through WARP (AI services that block datacenter IPs)
WARP_DOMAINS=(
    "domain:gemini.google.com"
    "domain:bard.google.com"
    "domain:aistudio.google.com"
    "domain:generativelanguage.googleapis.com"
    "domain:alkalimakersuite-pa.clients6.google.com"
    "domain:makersuite.google.com"
    "domain:deepmind.google"
    "domain:notebooklm.google.com"
    "domain:ai.google.dev"
    "domain:labs.google"
    "domain:openai.com"
    "domain:chatgpt.com"
    "domain:chat.openai.com"
    "domain:claude.ai"
    "domain:anthropic.com"
    "domain:meta.ai"
    "domain:copilot.microsoft.com"
    "domain:perplexity.ai"
    "domain:sora.com"
)
