# config.env — VPN deployment settings
# No secrets here. Safe to commit.

# Number of VPN users to generate
NUM_USERS=11

# Xray listen port on exit server
XRAY_PORT=8443

# Reality SNI — must support TLS 1.3
SNI="www.github.com"

# TLS fingerprint
FINGERPRINT="chrome"

# Relay ports that forward to exit node
RELAY_PORTS=(443 8444)
